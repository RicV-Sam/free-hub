{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://freehub.co.za/schemas/free-resource.schema.json",
  "title": "Freehub FreeResource",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "resourceType",
    "category",
    "categoryLabel",
    "officialUrl",
    "bestFor",
    "freeDetails",
    "requirements",
    "watchOut",
    "availability",
    "verificationStatus",
    "datePublished",
    "lastReviewed",
    "reviewDueAt",
    "dateModified"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "resourceType": { "enum": ["programme", "platform", "directory", "public_service", "guide"] },
    "category": { "type": "string", "minLength": 1 },
    "categoryLabel": { "type": "string", "minLength": 1 },
    "officialUrl": { "type": "string", "format": "uri", "pattern": "^https?://" },
    "bestFor": { "type": "string", "minLength": 1 },
    "freeDetails": { "type": "string", "minLength": 1 },
    "requirements": { "type": "string", "minLength": 1 },
    "watchOut": { "type": "string", "minLength": 1 },
    "availability": { "enum": ["active", "manual_check", "retired"] },
    "verificationStatus": { "enum": ["verified", "verification_due", "source_changed", "rejected"] },
    "datePublished": { "$ref": "#/$defs/date" },
    "lastReviewed": { "$ref": "#/$defs/date" },
    "reviewDueAt": { "$ref": "#/$defs/date" },
    "dateModified": { "$ref": "#/$defs/date" }
  },
  "$defs": {
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
  }
}
