{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://freehub.co.za/schemas/opportunity.schema.json",
  "title": "Freehub Opportunity",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "slug",
    "type",
    "title",
    "summary",
    "provider",
    "sourceUrl",
    "publicationStatus",
    "verificationStatus",
    "country",
    "regions",
    "lastVerifiedAt",
    "reviewDueAt",
    "updatedAt",
    "availabilityKind",
    "costClassification",
    "requirements",
    "categories",
    "tags",
    "details"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "slug": { "type": "string", "minLength": 1, "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "type": {
      "enum": [
        "free_sample",
        "birthday_freebie",
        "product_testing",
        "free_course",
        "free_ticket",
        "free_trial",
        "free_data_airtime",
        "reward",
        "cashback",
        "other_freebie"
      ]
    },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "provider": { "type": "string", "minLength": 1 },
    "sourceUrl": { "type": "string", "format": "uri", "pattern": "^https?://" },
    "termsUrl": { "type": "string", "format": "uri", "pattern": "^https?://" },
    "imageUrl": { "type": "string", "format": "uri", "pattern": "^https?://" },
    "publicationStatus": { "enum": ["draft", "review", "published", "held", "expired", "rejected"] },
    "verificationStatus": {
      "enum": [
        "unverified",
        "source_found",
        "requirements_checked",
        "verified",
        "verification_due",
        "source_changed",
        "expired",
        "rejected"
      ]
    },
    "country": { "const": "ZA" },
    "regions": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "startsAt": { "$ref": "#/$defs/date" },
    "expiresAt": { "$ref": "#/$defs/date" },
    "lastVerifiedAt": { "$ref": "#/$defs/date" },
    "reviewDueAt": { "$ref": "#/$defs/date" },
    "publishedAt": { "$ref": "#/$defs/date" },
    "updatedAt": { "$ref": "#/$defs/date" },
    "availabilityKind": { "enum": ["fixed_window", "stock_limited", "recurring", "ongoing"] },
    "costClassification": {
      "enum": [
        "completely_free",
        "free_entry",
        "standard_data_may_apply",
        "account_required",
        "membership_required",
        "app_required",
        "purchase_required",
        "delivery_fee",
        "refundable_deposit",
        "paid_trial_after_free_period",
        "card_required",
        "paid_entry",
        "unclear"
      ]
    },
    "requirements": {
      "type": "array",
      "items": { "$ref": "https://freehub.co.za/schemas/requirement.schema.json" }
    },
    "eligibility": { "type": "object" },
    "categories": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "tags": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "details": { "type": "object" }
  },
  "$defs": {
    "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "freeSampleDetails": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fulfilmentMethod", "deliveryCharge", "stockState", "householdLimit", "selectionStatus", "expectedFulfilmentWindow"],
      "properties": {
        "fulfilmentMethod": { "enum": ["delivery", "collection", "digital", "mixed"] },
        "deliveryCharge": { "enum": ["none", "required", "unknown"] },
        "stockState": { "enum": ["available", "limited", "application_only", "unknown"] },
        "householdLimit": { "type": ["integer", "null"], "minimum": 1 },
        "selectionStatus": { "enum": ["guaranteed", "selected_participants", "first_come_first_served", "unknown"] },
        "expectedFulfilmentWindow": { "type": "string", "minLength": 1 },
        "privacyUrl": { "type": "string", "format": "uri", "pattern": "^https://" }
      }
    },
    "productTestingDetails": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fulfilmentMethod", "selectionMethod", "stockState", "questionnaireRequired", "reviewRequired"],
      "properties": {
        "fulfilmentMethod": { "enum": ["delivery", "collection", "digital"] },
        "selectionMethod": { "enum": ["application", "questionnaire", "random_draw", "provider_selection"] },
        "stockState": { "enum": ["open", "limited", "closed"] },
        "questionnaireRequired": { "type": "boolean" },
        "reviewRequired": { "type": "boolean" }
      }
    },
    "birthdayDetails": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signupLeadDays",
        "birthdayWindow",
        "membershipRequired",
        "appRequired",
        "identityRequired",
        "branchAvailability",
        "recurrence",
        "voucherDelivery"
      ],
      "properties": {
        "signupLeadDays": { "type": "integer", "minimum": 0 },
        "birthdayWindow": {
          "type": "object",
          "additionalProperties": false,
          "required": ["beforeDays", "afterDays"],
          "properties": {
            "beforeDays": { "type": "integer", "minimum": 0 },
            "afterDays": { "type": "integer", "minimum": 0 }
          }
        },
        "membershipRequired": { "type": "boolean" },
        "appRequired": { "type": "boolean" },
        "identityRequired": { "type": "boolean" },
        "branchAvailability": { "enum": ["all_branches", "participating_branches", "online_only"] },
        "recurrence": { "enum": ["annual", "once"] },
        "voucherDelivery": { "enum": ["app", "email", "sms", "account", "in_store", "none"] }
      }
    },
    "courseDetails": {
      "type": "object",
      "additionalProperties": false,
      "required": ["duration", "accessMode", "certificateCost", "languages", "difficulty", "schedule", "geographicRestrictions"],
      "properties": {
        "duration": { "type": "string", "minLength": 1 },
        "accessMode": { "enum": ["online", "in_person", "hybrid"] },
        "certificateCost": { "enum": ["free", "paid", "none", "unclear"] },
        "languages": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "difficulty": { "enum": ["beginner", "intermediate", "advanced", "mixed", "not_stated"] },
        "schedule": { "enum": ["self_paced", "fixed_dates", "cohort"] },
        "geographicRestrictions": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
      }
    }
  },
  "allOf": [
    { "if": { "properties": { "type": { "const": "free_sample" } } }, "then": { "properties": { "details": { "$ref": "#/$defs/freeSampleDetails" } } } },
    { "if": { "properties": { "type": { "const": "product_testing" } } }, "then": { "properties": { "details": { "$ref": "#/$defs/productTestingDetails" } } } },
    { "if": { "properties": { "type": { "const": "birthday_freebie" } } }, "then": { "properties": { "details": { "$ref": "#/$defs/birthdayDetails" } } } },
    { "if": { "properties": { "type": { "const": "free_course" } } }, "then": { "properties": { "details": { "$ref": "#/$defs/courseDetails" } } } },
    {
      "if": {
        "properties": {
          "type": { "enum": ["free_ticket", "free_trial", "free_data_airtime", "reward", "cashback", "other_freebie"] }
        }
      },
      "then": { "properties": { "details": { "type": "object", "maxProperties": 0 } } }
    }
  ]
}
