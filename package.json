{
  "name": "free-hub-static",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "node scripts/generate-pages.js",
    "discover:bing": "node scripts/bing-search-discovery.js",
    "email:alerts": "node scripts/queue-email-alerts.js",
    "generate": "node scripts/generate-pages.js",
    "import:held-candidates": "node scripts/import-held-candidates.js",
    "export:held-review": "node scripts/export-held-review.js",
    "report:active-quality": "node scripts/active-listing-quality-report.js",
    "lint": "node scripts/validate-held-candidates.js --allow-missing && node scripts/validate-link-baseline.js",
    "validate:held-candidates": "node scripts/validate-held-candidates.js",
    "test:held": "node scripts/validate-held-candidates.js --allow-missing",
    "test:seo": "node scripts/validate-seo-baseline.js && node scripts/validate-performance-baseline.js",
    "test:lifecycle": "node --test tests/lifecycle/page-data.test.js tests/lifecycle/archive-cost-compatibility.test.js tests/lifecycle/opportunity-data.test.js tests/lifecycle/warning-baseline.test.js",
    "test:browser": "playwright test",
    "test:baseline": "npm run test:seo && npm run test:lifecycle",
    "baseline:update:warnings": "node scripts/update-link-warning-baseline.js --update",
    "validate:all": "npm test && npm run lint && node scripts/validate-maintenance-state.js",
    "test": "npm run test:held && npm run test:baseline"
  },
  "dependencies": {
    "firebase-admin": "^13.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1"
  }
}
