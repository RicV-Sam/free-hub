# Copy this file to .env and fill in local values.
# Do not commit real secrets.

# Required for scripts/bing-search-discovery.js when using a live endpoint.
BING_SEARCH_API_KEY=

# Optional. Defaults to the legacy Bing Web Search v7 endpoint.
BING_SEARCH_ENDPOINT=https://api.bing.microsoft.com/v7.0/search

# Optional. Defaults to en-ZA for South African competition discovery.
BING_SEARCH_MKT=en-ZA

# Optional. Example values historically included Day, Week, or Month.
BING_SEARCH_FRESHNESS=

# Optional Firebase account foundation.
# These are public web app identifiers, not service-account credentials.
# Prefer creating firebase-config.json from firebase-config.example.json for static hosting.
FREEHUB_FIREBASE_API_KEY=
FREEHUB_FIREBASE_AUTH_DOMAIN=
FREEHUB_FIREBASE_PROJECT_ID=
FREEHUB_FIREBASE_STORAGE_BUCKET=
FREEHUB_FIREBASE_MESSAGING_SENDER_ID=
FREEHUB_FIREBASE_APP_ID=
FREEHUB_FIREBASE_MEASUREMENT_ID=

# Optional Firebase Admin email alert queue.
# Used only by scripts/queue-email-alerts.js. Never commit the service account file.
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_PROJECT_ID=
FREEHUB_MAIL_COLLECTION=mail
FREEHUB_EMAIL_CAMPAIGN_COLLECTION=emailCampaigns
