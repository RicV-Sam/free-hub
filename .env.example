# Copy this file to .env and fill in local values.
# Do not commit real secrets.

# Required for scripts/bing-search-discovery.js when using a live endpoint.
BING_SEARCH_API_KEY=

# Optional. Defaults to the legacy Bing Web Search v7 endpoint.
BING_SEARCH_ENDPOINT=https://api.bing.microsoft.com/v7.0/search

# Optional. Defaults to en-ZA for South African competition discovery.
BING_SEARCH_MKT=en-ZA

# Optional. Example values historically included Day, Week, or Month.
BING_SEARCH_FRESHNESS=
